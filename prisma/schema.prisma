// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  HTML_NOTICE
  PDF_BULLETIN
  PRESS_RELEASE
  MANUAL_OVERRIDE
  GEMINI_SEARCH
}

enum ExamEventType {
  REGISTRATION
  EXAM
  COUNSELLING
  RESULT
  SEAT_ALLOTMENT
}


model College {
  id                   String      @id @default(cuid())
  name                 String
  slug                 String      @unique
  location             String
  state                String
  city                 String
  fees_min             Int
  fees_max             Int
  rating               Float
  nirf_rank            Int?
  placement_percentage Float
  avg_salary           Int?
  description          String      @db.Text
  image_url            String?
  website              String?
  established          Int?
  type                 CollegeType
  min_rank             Int?
  max_rank             Int?
  exam                 String[]
  accreditation        String?

  // New Features
  ai_summary           String?     @db.Text
  tags                 String[]
  best_for             String[]
  streams              String[]
  // Enrichment Pipeline Data
  image_source         String?
  domain_trust         String?
  image_score          Int?
  enriched_at          String?
  verification_priority String?

  courses       Course[]
  reviews       Review[]
  acceptedExams Exam[]
  shortlistedBy Shortlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
  @@index([city])
  @@index([nirf_rank])
  @@index([rating])
  @@index([fees_min])
  @@index([placement_percentage])
  @@index([slug])
}

model Exam {
  id                    String      @id @default(cuid())
  name                  String      @unique
  slug                  String      @unique
  authority             String?
  official_website      String?
  notices_url           String?
  
  colleges              College[]
  events                ExamEvent[]
  trackedBy             TrackedExam[]

  // Telemetry & Monitoring
  last_verified_at      DateTime?
  last_changed_at       DateTime?
  parser_version        String?
  parser_health         String?     // "HEALTHY", "WARNING", "FAILED"
}

model ExamEvent {
  id                  String      @id @default(cuid())
  examId              String
  exam                Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  type                ExamEventType
  title               String      // e.g. "Session 1 Registration", "Phase 2 Exam"
  
  startDate           DateTime
  endDate             DateTime?
  is_tentative        Boolean     @default(false)
  
  // Auditing
  source_url          String?
  source_type         SourceType?
  confidence_score    Float       @default(0.0)
  raw_text_snapshot   String?     @db.Text
  
  @@index([examId])
}

model Course {
  id        String  @id @default(cuid())
  name      String
  duration  String
  fees      Int
  seats     Int?
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  collegeId String
  cutoffs   Cutoff[]

  @@index([collegeId])
  @@index([name])
}

model Review {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Float
  comment   String   @db.Text
  batch     String?
  verified  Boolean  @default(false)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  collegeId String
  createdAt DateTime @default(now())

  @@index([collegeId])
  @@index([userId])
}

model Cutoff {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  exam         String   // e.g., "JEE Main", "NEET UG"
  year         Int      // e.g., 2023, 2024
  round        Int      // e.g., 1, 2, 6
  category     String   // "OPEN", "OBC-NCL", "SC", "ST", "EWS"
  quota        String   // "HS", "OS", "AI"
  seat_pool    String   // "Gender-Neutral", "Female-only"
  closing_rank Int
  
  @@index([courseId, category, quota, seat_pool])
}

enum CollegeType {
  GOVERNMENT
  PRIVATE
  DEEMED
  AUTONOMOUS
}

// -----------------------------------------------------------------------------
// Authentication (NextAuth / Auth.js)
// -----------------------------------------------------------------------------

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  shortlists    Shortlist[]
  trackedExams  TrackedExam[]
  reviews       Review[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// User Features
// -----------------------------------------------------------------------------

model Shortlist {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
  @@index([userId])
  @@index([collegeId])
}

model TrackedExam {
  id        String   @id @default(cuid())
  userId    String
  examId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([userId])
  @@index([examId])
}
